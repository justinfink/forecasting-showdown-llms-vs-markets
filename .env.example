# Copy this file to .env and fill in your API keys.
# .env is gitignored — your keys will never be committed.

# ── Original study models (lab.ipynb) ─────────────────────────────────────
OPENAI_API_KEY=sk-...           # GPT-4o — platform.openai.com
GOOGLE_API_KEY=AIzaSy...        # Gemini 2.5 Flash — aistudio.google.com
GEMINI_API_KEY=AIzaSy...        # (alias for GOOGLE_API_KEY)
ANTHROPIC_API_KEY=sk-ant-...    # Claude Sonnet 4 — console.anthropic.com

# ── Frontier model extension (frontier_models.py) ─────────────────────────
# o3 + Claude Opus 4.6 + Gemini 2.5 Pro reuse keys above.
#
# xAI Grok 3 — console.x.ai
XAI_API_KEY=xai-...
#
# DeepSeek-R1 — platform.deepseek.com
DEEPSEEK_API_KEY=sk-...

# ── Economic data (both free, not used in current analysis) ───────────────
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# EIA: https://www.eia.gov/opendata/
EIA_API_KEY=
